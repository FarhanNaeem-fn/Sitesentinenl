# ╔══════════════════════════════════════════════════════════════════════╗
# ║         SiteSentinel Matrix Pro — Backend Environment Config         ║
# ║  Copy this file to .env and fill in your credentials.               ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────────
# PROXY: Active provider — pick ONE, leave others blank to save memory
#
# "cloudflare"  → FREE — Cloudflare Worker reverse proxy (see cloudflare/)
#                 No city-level targeting. Uses CF Smart Placement.
#                 Also enables CF Worker for the live-preview iframe.
#                 Requires: CF_WORKER_URL + CF_WORKER_SECRET below.
#
# "brightdata"  → Residential forward proxy — city-level targeting
# "oxylabs"     → Residential forward proxy — city-level targeting
# "dataimpulse" → Residential forward proxy — pay-per-GB
# "iproyal"     → Residential forward proxy — affordable
# "decodo"      → Residential forward proxy — HTTP + SOCKS5
#
# Leave blank to disable proxy (all requests go direct)
# ──────────────────────────────────────────────────────────────────────
ACTIVE_PROXY_PROVIDER=cloudflare

# ──────────────────────────────────────────────────────────────────────
# CLOUDFLARE WORKER (reverse proxy — FREE tier)
# ──────────────────────────────────────────────────────────────────────
# Deploy steps:
#   cd cloudflare/
#   npm install -g wrangler
#   wrangler login
#   wrangler secret put PROXY_SECRET   ← enter a random secret string
#   wrangler deploy
#   Copy the printed URL to CF_WORKER_URL below.
#
# What it does:
#   • Strips X-Frame-Options / CSP — used by the live-preview iframe
#   • Returns X-CF-Colo / X-CF-Country / X-CF-City headers (geo metadata)
#   • Smart Placement routes to the CF PoP nearest the target origin
#
# Limitation:
#   Cannot target a specific city (Dubai vs. NY). For true geo-testing,
#   use a residential provider (brightdata / oxylabs / decodo).
# ──────────────────────────────────────────────────────────────────────
CF_WORKER_URL=https://sitesentinel-proxy.<your-subdomain>.workers.dev
CF_WORKER_SECRET=replace_with_strong_random_secret

# ── Bright Data (formerly Luminati) ───────────────────────────────────
# Dashboard: https://brightdata.com/cp
# Best for UAE & KSA — widest residential pool, city-level targeting
# Plan: Residential | Zone type: ISP or Residential
BRIGHTDATA_CUSTOMER_ID=brd-customer-XXXXXXXX
BRIGHTDATA_ZONE=residential_zone_name
BRIGHTDATA_PASSWORD=your_brightdata_password
BRIGHTDATA_HTTP_PORT=22225
BRIGHTDATA_SOCKS5_PORT=22228

# ── Oxylabs ───────────────────────────────────────────────────────────
# Dashboard: https://dashboard.oxylabs.io
# Good UAE/KSA success rate, city-level targeting, sticky sessions
OXYLABS_USERNAME=customer-YOUR_USERNAME
OXYLABS_PASSWORD=your_oxylabs_password
OXYLABS_PORT=7777

# ── DataImpulse ───────────────────────────────────────────────────────
# Dashboard: https://app.dataimpulse.com
# Cost-effective, good Middle East coverage, pay-per-GB
DATAIMPULSE_USERNAME=your_dataimpulse_username
DATAIMPULSE_PASSWORD=your_dataimpulse_password
DATAIMPULSE_HOST=proxy.dataimpulse.com
DATAIMPULSE_PORT=823

# ── IPRoyal ───────────────────────────────────────────────────────────
# Dashboard: https://iproyal.com/dashboard
# Affordable residential proxies, decent UAE coverage
IPROYAL_USERNAME=your_iproyal_username
IPROYAL_PASSWORD=your_iproyal_password
IPROYAL_PORT=12321

# ── Decodo (formerly Smartproxy) ──────────────────────────────────────
# Dashboard: https://dashboard.decodo.com
# Both HTTP + SOCKS5, solid UAE presence
DECODO_USERNAME=your_decodo_username
DECODO_PASSWORD=your_decodo_password
DECODO_HTTP_PORT=7000
DECODO_SOCKS5_PORT=7001

# ──────────────────────────────────────────────────────────────────────
# PROXY BEHAVIOUR
# ──────────────────────────────────────────────────────────────────────
# Max consecutive failures before auto-rotating session
PROXY_MAX_CONSECUTIVE_FAILURES=3
# Request timeout in seconds when using a proxy
PROXY_TIMEOUT_SEC=25
# Max retries per location before giving up
PROXY_MAX_RETRIES=3

# ──────────────────────────────────────────────────────────────────────
# PLAYWRIGHT / BROWSER
# ──────────────────────────────────────────────────────────────────────
BROWSER_WS_ENDPOINT=
# Set to 1 when running on Vercel
VERCEL=

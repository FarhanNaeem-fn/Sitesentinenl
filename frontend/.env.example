# ╔══════════════════════════════════════════════════════════════════════╗
# ║        SiteSentinel Matrix Pro — Frontend Environment Config         ║
# ║  Copy to .env.local (never commit real values to git)               ║
# ║  NOTE: VITE_ prefix exposes vars to the browser bundle.             ║
# ║        Proxy CREDENTIALS must NEVER have the VITE_ prefix.          ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Proxy UI preferences (safe to expose — no credentials) ────────────
VITE_PROXY_ENABLED=true
VITE_PROXY_DEFAULT_REGION=ae-dubai
VITE_PROXY_DEFAULT_SESSION_TYPE=rotating
VITE_PROXY_MAX_RETRIES=3
VITE_PROXY_TIMEOUT_MS=25000
VITE_PROXY_RATE_LIMIT_RPM=60

# ── API base URL override (optional) ──────────────────────────────────
# Leave blank to use the auto-detected base URL in client.ts
VITE_API_BASE_URL=
